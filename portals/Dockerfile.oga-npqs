FROM node:22-alpine AS build
RUN corepack enable && corepack prepare pnpm@10.28.1 --activate
WORKDIR /workspace
ARG VITE_INSTANCE_CONFIG=npqs
ENV VITE_INSTANCE_CONFIG=${VITE_INSTANCE_CONFIG}
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/ui/package.json packages/ui/
COPY packages/jsonforms-renderers/package.json packages/jsonforms-renderers/
COPY apps/oga-app/package.json apps/oga-app/
RUN pnpm install --frozen-lockfile
COPY packages/ packages/
COPY apps/oga-app/ apps/oga-app/
COPY tsconfig.json ./
RUN pnpm --filter oga-app build

FROM nginx:1.27-alpine
COPY --from=build /workspace/apps/oga-app/dist /usr/share/nginx/html
COPY apps/oga-app/nginx.conf /etc/nginx/conf.d/default.conf
COPY apps/oga-app/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
EXPOSE 80
ENTRYPOINT ["/entrypoint.sh"]
